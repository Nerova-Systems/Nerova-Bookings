{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$(git rev-parse --show-toplevel)/.codex/hooks/pre_tool_use_bash.py\"",
            "timeout": 30,
            "statusMessage": "Checking Bash command"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"$(git rev-parse --show-toplevel)/.codex/hooks/pre_tool_use_excuse_check.py\"",
            "timeout": 30,
            "statusMessage": "Checking tool input"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$(git rev-parse --show-toplevel)/.codex/hooks/post_tool_use_bash.py\"",
            "timeout": 30,
            "statusMessage": "Reviewing Bash output"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"$(git rev-parse --show-toplevel)/.codex/hooks/check_interrupt.py\"",
            "timeout": 30,
            "statusMessage": "Checking team interrupts"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"$(git rev-parse --show-toplevel)/.codex/hooks/stop_excuse_check.py\"",
            "timeout": 30,
            "statusMessage": "Checking final response"
          }
        ]
      }
    ]
  }
}
