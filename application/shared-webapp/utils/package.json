{
  "name": "@repo/utils",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rimraf ./dist && tsc -p .",
    "check": "oxfmt --check && oxlint",
    "dev": "tsc -p . -w",
    "dev:setup": "tsc -p .",
    "format": "oxfmt && (oxlint --fix --threads=1 || node -e \"process.exit(0)\")",
    "lint": "oxlint --deny-warnings --threads=1"
  },
  "devDependencies": {
    "@repo/config": "*"
  }
}
