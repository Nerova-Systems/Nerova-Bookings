{
  "ReverseProxy": {
    "Routes": {
      "account-static": {
        "Transforms": [
          {
            "PathPattern": "static/{**catch-all}"
          },
          {
            "ResponseHeader": "Cache-Control",
            "Set": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      "main-static": {
        "Transforms": [
          {
            "ResponseHeader": "Cache-Control",
            "Set": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    }
  }
}
